{
  "manifest_version": 3,
  "name": "Ebb",
  "version": "1.0.0",
  "description": "Your Claude usage quota, inline in the chat toolbar. Session and weekly limits at a glance.",
  "permissions": ["storage", "cookies", "alarms"],
  "host_permissions": ["https://claude.ai/*"],
  "background": { "service_worker": "background.js" },
  "content_scripts": [{
    "matches": ["https://claude.ai/*"],
    "js": ["content.js"],
    "css": ["style.css"],
    "run_at": "document_idle"
  }],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
